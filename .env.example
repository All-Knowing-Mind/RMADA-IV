# .env.example — Copie para .env e customize conforme necessário

# Servidor
PORT=8080
NODE_ENV=production

# Autenticação
OWNER_CODE=OWNER-SECRET-CHANGEME
DEFENSE_CODE=DEFENSE-SECRET-CHANGEME

# Dilithium (post-quantum crypto)
DILITHIUM_VERIFY=1
DILITHIUM_VERIFIER_BIN=/workspace/meu_projeto_dilithium/target/release/meu_projeto_dilithium

# WireGuard
WG_CONFIG_PATH=/workspace/wg-config/wg0.conf
WG_PRIVATE_KEY_PATH=/workspace/wg-config/server_wg.key
WG_PUBLIC_KEY_PATH=/workspace/wg-config/server_wg.pub

# Lightway (opcional, para Stage 2)
# LIGHTWAY_CONFIG_PATH=/etc/lightway/server.conf
# LIGHTWAY_ENABLED=false

# Logging
LOG_LEVEL=info

# Database (futuro — Stage 2)
# DATABASE_URL=file:./device-registry.db

# CORS e origin
# CORS_ORIGIN=http://localhost:8080

# TLS/HTTPS (futuro — Stage 2)
# TLS_KEY_PATH=/etc/certs/server.key
# TLS_CERT_PATH=/etc/certs/server.crt

# Telemetry ingest (pode apontarpara um serviço externo)
# TELEMETRY_ENDPOINT=http://localhost:8080/api/telemetry
